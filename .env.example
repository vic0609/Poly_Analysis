# ─── Polymarket ───────────────────────────────────────────────
# No API key needed for public read endpoints
# Only needed if you want to place orders
POLYMARKET_PRIVATE_KEY=

# ─── Polygon RPC ──────────────────────────────────────────────
# Free public fallback: https://polygon-rpc.com
# Recommended: Get a free key at https://dashboard.alchemy.com
POLYGON_RPC_URL=https://polygon-rpc.com
ALCHEMY_API_KEY=

# ─── Kalshi ───────────────────────────────────────────────────
# Public market data needs no key. Authenticated trading requires one.
KALSHI_EMAIL=
KALSHI_PASSWORD=

# ─── Social Media ─────────────────────────────────────────────
# Twitter/X API v2 - get at https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# Reddit - get at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=polymarket_edge_bot/1.0

# ─── Alerts ───────────────────────────────────────────────────
# Discord webhook (optional)
DISCORD_WEBHOOK_URL=
# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/polymarket_edge.db

# ─── Monitor Intervals (seconds) ──────────────────────────────
MARKET_POLL_INTERVAL=60
WHALE_POLL_INTERVAL=30
SENTIMENT_POLL_INTERVAL=300
ARBITRAGE_POLL_INTERVAL=30
EDGE_DETECTION_INTERVAL=120

# ─── Execution / Kelly ────────────────────────────────────────
# Set PAPER_TRADING=false only when ready to risk real money
PAPER_TRADING=true
BANKROLL_USDC=1000
HALF_KELLY=true
MAX_KELLY_FRACTION=0.1
MAX_POSITION_USDC=500
MIN_POSITION_USDC=5
# Tuned 2026-05-31: 50-59 edge score bucket is the sweet spot (57% WR, +3.8% ROI)
MIN_EDGE_SCORE_TO_TRADE=50
# 60-79 edge score bucket loses money (-0.8% to -14.9% ROI) — cap at sweet spot ceiling
MAX_EDGE_SCORE_TO_TRADE=65
# whale_accumulation disabled pending validation of direction-fix (re-enable after 7+ days clean data)
DISABLED_SIGNAL_TYPES=whale_accumulation
MIN_CONFIDENCE_TO_TRADE=0.70
MIN_PRICE_GAP_TO_TRADE=0.03
MAX_OPEN_POSITIONS=10
MAX_DAILY_LOSS_PCT=0.10
TAKE_PROFIT_PCT=1.00
STOP_LOSS_PCT=0.10
SETTLEMENT_INTERVAL=60
# Polymarket CLOB API key (only needed for live trading)
POLYMARKET_API_KEY=

# ─── Edge Detection Thresholds ────────────────────────────────
# Z-score threshold to flag a market as an outlier
ZSCORE_THRESHOLD=2.0
# Min arbitrage profit % to alert
MIN_ARB_PROFIT_PCT=1.5
# Whale trade minimum USDC size to track
WHALE_MIN_SIZE_USDC=5000
